{
  "name": "steam-collection-manager",
  "version": "1.0.5",
  "description": "A web-based Steam collection manager and library organizer",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "electron": "electron .",
    "electron-dev": "electron .",
    "build": "node scripts/bump-version.mjs && electron-builder --win",
    "bump-version": "node scripts/bump-version.mjs"
  },
  "build": {
    "appId": "com.steamcollectionmanager.app",
    "productName": "SteamCollectionManager",
    "icon": "icon.png",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "files": [
      "**/*",
      "main.js",
      "preload.js",
      "!server.mjs",
      "!config/**",
      "!cache/**",
      "!games_cache.json",
      "!steam_*_cache.json",
      "!**/{.git,.github,*.md,*.log}"
    ],
    "extraResources": [
      "server.mjs",
      "icon.png",
      "public/**/*",
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "express/**/*",
          "accepts/**/*",
          "array-flatten/**/*",
          "body-parser/**/*",
          "bytes/**/*",
          "call-bind-apply-helpers/**/*",
          "call-bound/**/*",
          "content-disposition/**/*",
          "content-type/**/*",
          "cookie-signature/**/*",
          "cookie/**/*",
          "debug/**/*",
          "depd/**/*",
          "destroy/**/*",
          "dunder-proto/**/*",
          "ee-first/**/*",
          "encodeurl/**/*",
          "es-define-property/**/*",
          "es-errors/**/*",
          "es-object-atoms/**/*",
          "escape-html/**/*",
          "etag/**/*",
          "finalhandler/**/*",
          "forwarded/**/*",
          "fresh/**/*",
          "function-bind/**/*",
          "get-intrinsic/**/*",
          "get-proto/**/*",
          "gopd/**/*",
          "has-symbols/**/*",
          "hasown/**/*",
          "http-errors/**/*",
          "iconv-lite/**/*",
          "inherits/**/*",
          "ipaddr.js/**/*",
          "math-intrinsics/**/*",
          "media-typer/**/*",
          "merge-descriptors/**/*",
          "methods/**/*",
          "mime-db/**/*",
          "mime-types/**/*",
          "mime/**/*",
          "ms/**/*",
          "negotiator/**/*",
          "object-inspect/**/*",
          "on-finished/**/*",
          "parseurl/**/*",
          "path-to-regexp/**/*",
          "proxy-addr/**/*",
          "qs/**/*",
          "range-parser/**/*",
          "raw-body/**/*",
          "safe-buffer/**/*",
          "safer-buffer/**/*",
          "send/**/*",
          "serve-static/**/*",
          "setprototypeof/**/*",
          "side-channel-list/**/*",
          "side-channel-map/**/*",
          "side-channel-weakmap/**/*",
          "side-channel/**/*",
          "statuses/**/*",
          "toidentifier/**/*",
          "type-is/**/*",
          "unpipe/**/*",
          "utils-merge/**/*",
          "vary/**/*",
          "hltb-client/**/*",
          "axios/**/*",
          "follow-redirects/**/*",
          "form-data/**/*",
          "https-proxy-agent/**/*",
          "proxy-from-env/**/*",
          "asynckit/**/*",
          "combined-stream/**/*",
          "delayed-stream/**/*",
          "es-set-tostringtag/**/*",
          "has-tostringtag/**/*",
          "has-symbols/**/*",
          "agent-base/**/*",
          "punycode/**/*",
          "querystringify/**/*",
          "requires-port/**/*",
          "tough-cookie/**/*",
          "psl/**/*",
          "universalify/**/*",
          "url-parse/**/*",
          "cssstyle/**/*",
          "data-urls/**/*",
          "decimal.js/**/*",
          "@asamuzakjp/css-color/**/*",
          "@csstools/color-helpers/**/*",
          "@csstools/css-calc/**/*",
          "@csstools/css-color-parser/**/*",
          "@csstools/css-parser-algorithms/**/*",
          "@csstools/css-tokenizer/**/*",
          "lru-cache/**/*",
          "form-data/**/*",
          "html-encoding-sniffer/**/*",
          "http-proxy-agent/**/*",
          "https-proxy-agent/**/*",
          "is-potential-custom-element-name/**/*",
          "nwsapi/**/*",
          "parse5/**/*",
          "entities/**/*",
          "rrweb-cssom/**/*",
          "saxes/**/*",
          "symbol-tree/**/*",
          "w3c-xmlserializer/**/*",
          "webidl-conversions/**/*",
          "whatwg-encoding/**/*",
          "whatwg-mimetype/**/*",
          "whatwg-url/**/*",
          "tr46/**/*",
          "ws/**/*",
          "xml-name-validator/**/*",
          "xmlchars/**/*",
          "jsdom/**/*"
        ]
      }
    ],
    "asarUnpack": [
      "server.mjs"
    ]
  },
  "dependencies": {
    "cssstyle": "^4.0.1",
    "data-urls": "^5.0.0",
    "decimal.js": "^10.4.3",
    "@asamuzakjp/css-color": "^3.2.0",
    "@csstools/color-helpers": "^5.1.0",
    "@csstools/css-calc": "^2.1.3",
    "@csstools/css-color-parser": "^3.0.9",
    "@csstools/css-parser-algorithms": "^3.0.4",
    "@csstools/css-tokenizer": "^3.0.3",
    "lru-cache": "^10.4.3",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "hltb-client": "^1.0.1",
    "html-encoding-sniffer": "^4.0.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.5",
    "is-potential-custom-element-name": "^1.0.1",
    "jsdom": "^24.1.0",
    "nwsapi": "^2.2.12",
    "parse5": "^7.1.2",
    "psl": "^1.9.0",
    "punycode": "^2.3.1",
    "querystringify": "^2.2.0",
    "requires-port": "^1.0.0",
    "rrweb-cssom": "^0.8.0",
    "saxes": "^6.0.0",
    "symbol-tree": "^3.2.4",
    "tough-cookie": "^4.1.4",
    "universalify": "^2.0.1",
    "url-parse": "^1.5.10",
    "w3c-xmlserializer": "^5.0.0",
    "webidl-conversions": "^7.0.0",
    "whatwg-encoding": "^3.1.1",
    "whatwg-mimetype": "^4.0.0",
    "whatwg-url": "^14.0.0",
    "tr46": "^5.1.0",
    "ws": "^8.18.0",
    "xml-name-validator": "^5.0.0",
    "entities": "^6.0.0",
    "xmlchars": "^2.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
